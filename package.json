{
  "name": "openpot-secure-session-tracker",
  "version": "0.8.0",
  "description": "A premium, privacy-first session tracker designed for sovereignty and anonymity.",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "next dev",
    "dev:https": "bash ./scripts/dev-https.sh",
    "build": "next build",
    "build:local": "bash ./scripts/build.sh",
    "serve": "node scripts/serve.js",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@serwist/precaching": "^9.5.7",
    "@serwist/sw": "^9.5.7",
    "@serwist/window": "^9.5.7",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "^9.5.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.54.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "postcss": "^8.4.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
