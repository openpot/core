{
  "name": "openpot-secure-timer",
  "version": "0.24.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "serialize-javascript": "^7.0.5"
    }
  },
  "scripts": {
    "dev": "next dev",
    "dev:https": "bash ./scripts/dev-https.sh",
    "serve:pwa": "npm run build && node scripts/serve-https.js",
    "prebuild": "node -e \"const pkg=require('./package.json'); let h=process.env.BUILD_HASH; if(!h){try{h=require('child_process').execSync('git rev-parse --short HEAD').toString().trim()}catch(e){h='unknown'}}; require('fs').writeFileSync('./public/version.json', JSON.stringify({version: 'v' + pkg.version + '-' + h, timestamp: Date.now()}, null, 2))\"",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next build && npx serve -l ${PORT:-3000} out",
    "start:ci": "serve -l ${PORT:-3000} out",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test -c .workspace/playwright.config.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "next": "^15.5.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
